DATA_BLOCK DB 326
TITLE =
VERSION : 0.0


  STRUCT 	
   TmpAll : UDT 30;	
   TmpHcuInl : UDT 32;	
   TmpHcu001 : UDT 32;	
   TmpHcu002 : UDT 32;	
   TmpHcu003 : UDT 32;	
   TmpHcu004 : UDT 32;	
   TmpHcu005 : UDT 32;	
   PmtTmpHcuInl : UDT 34;	
   PmtTmpHcu001 : UDT 34;	
   PmtTmpHcu002 : UDT 34;	
   PmtTmpHcu003 : UDT 34;	
   PmtTmpHcu004 : UDT 34;	
   PmtTmpHcu005 : UDT 34;	
   PumHcuInl : UDT 43;	
   PumHcu001 : UDT 43;	
   PumHcu002 : UDT 43;	
   PumHcu003 : UDT 43;	
   PumHcu004 : UDT 43;	
   PumHcu005 : UDT 43;	
   TmpHcu004SetSel : BOOL ;	
   TmpHcu005SetSel : BOOL ;	
   Mst : UDT 62;	
   Drv001 : UDT 50;	
   Drv002 : UDT 50;	
   Drv003 : UDT 50;	
   Drv004 : UDT 50;	
   Drv005 : UDT 50;	
   TmpCor001 : UDT 68;	
   TmpCor002 : UDT 68;	
   TmpFla : UDT 68;	// old
   TCE : UDT 81;	
   Gen001 : UDT 82;	
   Gen002 : UDT 82;	
   Gen003 : UDT 82;	
   Gen004 : UDT 82;	
   Gen005 : UDT 82;	
   Flame : UDT 84;	
   CorTop : UDT 82;	
   CorBot : UDT 82;	
   EdtAmp : UDT 60;	
  END_STRUCT ;	
BEGIN
   TmpAll.Vrs := 0.000000e+000; 
   TmpAll.RunCmd := FALSE; 
   TmpAll.StpCmd := FALSE; 
   TmpAll.RstCmd := FALSE; 
   TmpAll.ActOk := FALSE; 
   TmpAll.SetAcv := FALSE; 
   TmpAll.SetSel := 0; 
   TmpAll.Mode := 0; 
   TmpAll.Set := 0.000000e+000; 
   TmpAll.ZonCou := 0; 
   TmpAll.RunSttCou := 0; 
   TmpAll.AlaSumCou := 0; 
   TmpAll.AlaMinCou := 0; 
   TmpAll.AlaMaxCou := 0; 
   TmpAll.AlaSenCou := 0; 
   TmpAll.WarSumCou := 0; 
   TmpAll.WarMinCou := 0; 
   TmpAll.WarMaxCou := 0; 
   TmpAll.StaTimSet := 0.000000e+000; 
   TmpAll.StaTimAct := 0.000000e+000; 
   TmpAll.LivCou := 0; 
   TmpHcuInl.Vrs := 0.000000e+000; 
   TmpHcuInl.Dsa := W#16#0; 
   TmpHcuInl.RunCmd := FALSE; 
   TmpHcuInl.StpCmd := FALSE; 
   TmpHcuInl.RstCmd := FALSE; 
   TmpHcuInl.RunStt := FALSE; 
   TmpHcuInl.Mode := 0; 
   TmpHcuInl.Set := 0.000000e+000; 
   TmpHcuInl.SetMne := 0.000000e+000; 
   TmpHcuInl.SetAux := 0.000000e+000; 
   TmpHcuInl.SetMod := W#16#0; 
   TmpHcuInl.SetSel := 0; 
   TmpHcuInl.Act := 0.000000e+000; 
   TmpHcuInl.Y := 0.000000e+000; 
   TmpHcuInl.X := 0.000000e+000; 
   TmpHcuInl.InpSen := FALSE; 
   TmpHcuInl.AlaMod := W#16#0; 
   TmpHcuInl.AlaSum := FALSE; 
   TmpHcuInl.AlaMin := FALSE; 
   TmpHcuInl.AlaMax := FALSE; 
   TmpHcuInl.AlaSen := FALSE; 
   TmpHcuInl.ActMin := 0.000000e+000; 
   TmpHcuInl.ActMax := 0.000000e+000; 
   TmpHcuInl.WarMod := W#16#0; 
   TmpHcuInl.WarSum := FALSE; 
   TmpHcuInl.WarMin := FALSE; 
   TmpHcuInl.WarMax := FALSE; 
   TmpHcuInl.X_Min := 0.000000e+000; 
   TmpHcuInl.X_Max := 0.000000e+000; 
   TmpHcuInl.SetMin := 0.000000e+000; 
   TmpHcuInl.SetMax := 0.000000e+000; 
   TmpHcuInl.ActOk := FALSE; 
   TmpHcuInl.ActOk_Sel := FALSE; 
   TmpHcuInl.ActOk_On_Set := 0.000000e+000; 
