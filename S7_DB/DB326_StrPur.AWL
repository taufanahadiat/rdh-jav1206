TYPE UDT 84
VERSION : 0.1


  STRUCT 	
   Read : STRUCT 	//Read data from S7-1200 Flame EsseCi
    Status : STRUCT 	
     FlameRun : BOOL ;	//Flame Run Status
     IgnitFault : BOOL ;	//Ignition fault
     CombFlt : BOOL ;	//Combustion Fan Fault
     BlowSysFlt : BOOL ;	//Blowing System Fault
     GasPressLow : BOOL ;	//Gas Pressure Low
     SpeedLow : BOOL ;	//Speed too Low
     CombPressLow : BOOL ;	//Combustion Air Pressure Low
     FlameDetFlt : BOOL ;	//Flame Detection Fault
     BackVlvFlt : BOOL ;	//BackFlash Valve Fault
     WaterCoolFlt : BOOL ;	//Water Cooling Fault
     EStop : BOOL ;	//Flame Treatment E-stop Actuated
     PurFlaWpo : BOOL ;	//Purroll Flame Waiting Operation
     LocalMode : BOOL ;	//Local Mode
    END_STRUCT ;	
    FlameTemp : INT ;	//Flame Temperature (AGR)
    BurnCoolTemp : INT ;	//Burner Cooling Water Temperature
    Spare : ARRAY  [1 .. 13 ] OF INT ;	
   END_STRUCT ;	
   Write : STRUCT 	//Write data to S7-1200 Flame EsseCi
    Status : STRUCT 	
     CoolingOn : BOOL ;	//Cooling Unit On Stt
     Release : BOOL ;	//Release Ignition
     BurnCls : BOOL ;	//Burner Close
     BurnOpn : BOOL ;	//Burner Open
     HornRst : BOOL ;	//Horn Reset
    END_STRUCT ;	
    Spare : ARRAY  [1 .. 15 ] OF INT ;	
   END_STRUCT ;	
   Ctrl : STRUCT 	//Control From Main PLC
    FlameRun : BOOL ;	//Flame Run Status
    IgnitFault : BOOL ;	//Ignition fault
    CombFlt : BOOL ;	//Combustion Fan Fault
    BlowSysFlt : BOOL ;	//Blowing System Fault
    GasPressLow : BOOL ;	//Gas Pressure Low
    SpeedLow : BOOL ;	//Speed too Low
    CombPressLow : BOOL ;	//Combustion Air Pressure Low
    FlameDetFlt : BOOL ;	//Flame Detection Fault
    BackVlvFlt : BOOL ;	//BackFlash Valve Fault
    WaterCoolFlt : BOOL ;	//Water Cooling Fault
    EStop : BOOL ;	//Flame Treatment E-stop Actuated
    PurFlaWpo : BOOL ;	//Purroll Flame Waiting Operation
    LocalMode : BOOL ;	//Local Mode
    FlameTemp : INT ;	//Flame Temperature (AGR)
    BurnCoolTemp : INT ;	//Burner Cooling Water Temperature
    MinLineSpeed : INT  := 40;	//Minimum Line Speed
    spare2 : INT ;	
    CoolingOn : BOOL ;	//Cooling Unit On Stt
    Release : BOOL ;	//Release Ignition
    BurnCls : BOOL ;	//Burner Close
    BurnOpn : BOOL ;	//Burner Open
    HornRst : BOOL ;	//Horn Reset
    StartBurner : BOOL ;	//Start Burner
    Interlock : STRUCT 	//Interlock Transfer From Line
     NipRollCls : BOOL ;	//Nip Roll Flame Closed
     HCU1Run : BOOL ;	//HCU 1 Temp Control Run
     LineSpeedOK : BOOL ;	//Line Speed
     MStop : BOOL ;	//M-Stop Machine
     FilmBreak : BOOL ;	//Film Break
     ProdModeActive : BOOL ;	//Production Mode Active
     Loc_Rem_Mode : BOOL ;	//Mode Select
     Select : BOOL ;	//Activation Select
    END_STRUCT ;	
    spare4 : WORD ;	
   END_STRUCT ;	
  END_STRUCT ;	
END_TYPE

