DATA_BLOCK DB 330
TITLE =
VERSION : 0.0


  STRUCT 	
   PowSwt : UDT 65;	// Power Switch
   Psu220_Ac : UDT 65;	// Power Supply 220Vac
   Psu024_Dc : UDT 65;	// Power Supply 24Vdc
   Psu015_Dc : UDT 65;	// Power Supply 15Vdc
   SwbFan : UDT 65;	// Switchboard Fan
   LnkFlt : UDT 65;	// Link S7 -> S5 STR
   GnlMacDsa : WORD ;	
   Con : STRUCT 	// Contact Roll:
    Drv : UDT 50;	// Contact Roll Drive
