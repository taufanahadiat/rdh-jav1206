  END_STRUCT ;	
END_TYPE

TYPE UDT 32
// udt32


  STRUCT 	
   Vrs : REAL ;	// version
   Dsa : WORD ;	// disabled
   RunCmd : BOOL ;	// run command
   StpCmd : BOOL ;	// stop command
   RstCmd : BOOL ;	// reset command
   RunStt : BOOL ;	// run status
   Mode : INT ;	// mode
   Set : REAL ;	// setpoint
   SetMne : REAL ;	// main setpoint
   SetAux : REAL ;	// aux. setpoint
   SetMod : WORD ;	// mode setpoint
   SetSel : INT ;	// setpoint select
   Act : REAL ;	// actual
   Y : REAL ;	// output controller
   X : REAL ;	// deviation
   InpSen : BOOL ;	// input sensor [used for fault]
   AlaMod : WORD ;	// alarm mode
   AlaSum : BOOL ;	// alarm summary
   AlaMin : BOOL ;	// alarm actual min.
   AlaMax : BOOL ;	// alarm actual max.
   AlaSen : BOOL ;	// alarm sensor
   ActMin : REAL ;	// limit actual min.
   ActMax : REAL ;	// limit actual max.
   WarMod : WORD ;	// warning mode
   WarSum : BOOL ;	// warning summary
   WarMin : BOOL ;	// warning dev. min
   WarMax : BOOL ;	// warning dev. max
   X_Min : REAL ;	// limit dev. min.
   X_Max : REAL ;	// limit dev. max.
   SetMin : REAL ;	// setpoint limit min.
   SetMax : REAL ;	// setpoint limit max.
   ActOk : BOOL ;	// actual ok
   ActOk_Sel : BOOL ;	// actual ok - Select
   ActOk_On_Set : REAL ;	// actual ok - on setpoint
   ActOk_OffSet : REAL ;	// actual ok - off setpoint
   ActOk_On_DelSet : REAL ;	// actual ok - on delay setpoint
   ActOk_On_DelAct : REAL ;	// actual ok - on delay actual
   ActOk_OffDelSet : REAL ;	// actual ok - off delay setpoint
   ActOk_OffDelAct : REAL ;	// actual ok - off delay actual
   LivCou : INT ;	// live counter
  END_STRUCT ;	
END_TYPE

TYPE UDT 36
// udt36


  STRUCT 	// version 
   Vrs : REAL ;	// mode's 
   Mode : INT ;	
   Ini : BOOL ;	// S,W,Y,X,Tg 
   W : REAL ;	// setpoint 
   InpAct : REAL ;	// actual (input) 
   X : REAL ;	// actual (input filtered) 
   X_Stt : REAL ;	// actual (effective) 
   Y : REAL ;	// controller output 
   Xw : REAL ;	// deviation 
   Tg : REAL ;	// filter time 
// controller output 
   Y_Man : REAL ;	// controller output manual 
   Y_Min : REAL ;	// controller output min 
   Y_Max : REAL ;	// controller output max 
   Y_Ofs : REAL ;	// controller output offset (disturbance) 
   Y_PerOfs : REAL ;	// controller output peripherie offset 
   Y_PerFac : REAL ;	// controller output peripherie factor 
   Y_Per : WORD ;	// controller output peripherie 
   Y_MinAcv : BOOL ;	// controller output at low limit 
   Y_MaxAcv : BOOL ;	// controller output at high limit 
// controller parameters 
   Kp : REAL ;	// proportional gain 
   Ti : REAL ;	// integral time 
   Td : REAL ;	// derivative time 
   Tdf : REAL ;	// time lag of derivative time 
   Dbd : REAL ;	// dead band 
   Ts : REAL ;	// sample time 
// actual value from peripherie 
   InpPer : WORD ;	
   InpPerFac : REAL ;	
   InpPerOfs : REAL ;	
   InpPerAcv : BOOL ;	// activation of components for contr. output 
   Kp_Acv : BOOL ;	
   Ti_Acv : BOOL ;	
   Td_Acv : BOOL ;	// manipulation of integral part 
   Ti_Hld : BOOL ;	
   Ti_Ini : BOOL ;	
   Ti_Set : REAL ;	// components of controller output 
   Kp_Act : REAL ;	
   Ti_Act : REAL ;	
   Td_Act : REAL ;	// internal data for S7-controller 
   sInvAlt : REAL ;	
   sIanteilAlt : REAL ;	
   SRestInt : REAL ;	
   sRestDif : REAL ;	
   sRueck : REAL ;	
   sLmn : REAL ;	
   sbArwHLmOn : BOOL ;	
   sbArwLLmOn : BOOL ;	
   sbILimOn : BOOL ;	// internal counter for time-tact 
   ZonCou : INT ;	// live counter 
   LivCou : INT ;	
  END_STRUCT ;	
END_TYPE

