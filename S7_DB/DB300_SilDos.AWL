DATA_BLOCK DB 300
TITLE =
VERSION : 0.0


  STRUCT 	// silo mstop
   Mst : UDT 62;	// feeding storage
   StoPipFlp : UDT 40;	
   StoRunStp : UDT 64;	
   StoBlwFan : UDT 41;	
   StoRotVlv : UDT 42;	// Level indication
   BigBag : UDT 72;	// bigbag
   Sil001 : UDT 72;	// silo 1
   Sil002 : UDT 72;	// silo 2
   Sil001Hop : UDT 72;	// Silo 1 hopper
   Dos003Hop : UDT 72;	// MB hopper
   Dos004Hop : UDT 72;	// dosing 4 hopper
// Dosing
   DosHop : UDT 72;	// dosing hopper
   DosGbl : UDT 71;	
   Dos001 : UDT 70;	
   Dos002 : UDT 70;	
   Dos003 : UDT 70;	
   Dos004 : UDT 70;	// extruder
   ExtMixHop : UDT 72;	
   ExtRunStp : UDT 64;	
   ExtBlwFan : UDT 41;	
   ExtRotVlv : UDT 42;	
   ExtMixMot : UDT 42;	
   ExtMixPus : UDT 74;	
   ExtMixMsp : UDT 73;	
   LvlCtl : UDT 32;	
