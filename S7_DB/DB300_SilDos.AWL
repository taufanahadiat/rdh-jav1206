   LvlMaxDelAct : REAL ;	// level max delay actual
   LvlMinDelSet : REAL ;	// level min delay setpoint
   LvlMinDelAct : REAL ;	// level min delay actual
   OffDelSet : REAL ;	// off delay setpoint
   OffDelAct : REAL ;	// off delay actual
   TimFllDelSet : REAL ;	// time fill delay setpoint
   TimFllDelAct : REAL ;	// time fill delay actual
   LivCou : INT ;	// live counter cmd
  END_STRUCT ;	
END_TYPE

TYPE UDT 71
// udt71


  STRUCT 	
   RunCmd : BOOL ;	// global run command
   StpCmd : BOOL ;	// global stop command
