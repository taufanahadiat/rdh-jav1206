   InpFlpCls : BOOL ;	// flap open input
   AlaMatFlt : BOOL ;	// alarm material fault
   FdgTimSet : REAL ;	// feeding cycle setpoint
   FdgTimAct : REAL ;	// feeding cycle actual
   EmpTimSet : REAL ;	// empting cycle setpoint
   EmpTimAct : REAL ;	// empting cycle actual
   CvrStaSet : REAL ;	// conveying valve start setpoint
   ScvStaSet : REAL ;	// scavenging valve start setpoint
   EmpStaSet : REAL ;	// empting valve start setpoint
   FanDelSet : REAL ;	// fan off delay setpoint
   FanDelAct : REAL ;	// fan off delay actual
   MatFltDelSet : REAL ;	// material fault delay setpoint
   MatFltDelAct : REAL ;	// material fault delay actual
   LivCou : INT ;	// live counter cmd
  END_STRUCT ;	
END_TYPE

