ORGANIZATION_BLOCK "Cyclic interrupt"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 0.1
   VAR_TEMP 
      EV_CLASS : Byte;   // Bits 0-3 = 1:Coming event, Bits 4-7 = 1:Event class 1
      STRT_INF : Byte;   // Start information
      PRIORITY : Byte;   // Priority of OB Execution
      OB_NUMBR : Byte;   // OB number
      RESERVED_1 : Byte;   // Reserved for system
      RESERVED_2 : Byte;   // Reserved for system
      PHS_OFFSET : Int;   // Phase offset
      RESERVED_3 : Int;   // Reserved for system
      EXC_FREQ : Int;   // Frequency of execution
      DATE_TIME : Date_And_Time;   // Date and time OB started
   END_VAR


BEGIN
	"FC_Fluct_Master"(Enable := TRUE,
	                  Seed := "DB_Sim".Seed_All);
	"FC_Fluct_DB330_Win_DB"(
	                        Enable     := TRUE,
	                        Amp_SpdMpm := 0.8,
	                        Amp_LoaPct := 0.5,
	                        Amp_PowKw  := 0.2,
	                        Amp_TmpC   := 0.8,
	                        Amp_TenNm  := 2.0,
	                        Amp_PrsN   := 10.0,
	                        Amp_PosMm  := 0.5,
	                        Seed       := "MD100"
	);
	
END_ORGANIZATION_BLOCK

