FUNCTION "FC_Fluct_DB311_ExtMel" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB311 (ExtMel)
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi
      Amp_PowKw : Real;   // kW
      Amp_SpdRpm : Real;   // rpm
      Amp_TmpC : Real;   // degC
      Amp_PrsBar : Real;   // bar
