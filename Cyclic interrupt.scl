FUNCTION "FC_Fluct_DB322_StrMdo" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB322 (StrMdo) - MDO
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi
      Amp_TmpC : Real;   // Â±Â°C
      Amp_Y_Pct : Real;   // Â±% drive speed & load
      Amp_SpdMpm : Real;   // Â± m/min
      Amp_LoaPct : Real;   // Â± %
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // =========================
	    // Drives (instruksi kamu)
	    // =========================
	    // MDO 1
	    "StrMdo".Drv001.SpdSet := "FC_NoiseReal"(Base := 28.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".Drv001.SpdAct := "FC_NoiseReal"(Base := 28.4, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".Drv001.LoaAct := "FC_NoiseReal"(Base := -13.5, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // MDO 2 (SpdSet tidak tampil di layar â†’ disamakan dengan Act)
	    "StrMdo".Drv002.SpdSet := "FC_NoiseReal"(Base := 159.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".Drv002.SpdAct := "FC_NoiseReal"(Base := 159.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".Drv002.LoaAct := "FC_NoiseReal"(Base := 5.5, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // MDO 3 (SpdSet tidak tampil di layar â†’ disamakan dengan Act)
	    "StrMdo".Drv003.SpdSet := "FC_NoiseReal"(Base := 171.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".Drv003.SpdAct := "FC_NoiseReal"(Base := 171.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".Drv003.LoaAct := "FC_NoiseReal"(Base := 12.1, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Auxiliary Winder (DrvAuw)
	    "StrMdo".DrvAuw.SpdSet := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".DrvAuw.SpdAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".DrvAuw.LoaAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // All Zone (ambil set tertinggi yg dominan di MDO: 114.0Â°C)
	    // =========================
	    "StrMdo".TmpAll.Set := "FC_NoiseReal"(Base := 114.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Preheating 1..5
	    // =========================
	    "StrMdo".TmpPrh001.Set := "FC_NoiseReal"(Base := 112.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh001.Act := "FC_NoiseReal"(Base := 112.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh001.Y := "FC_NoiseReal"(Base := 1.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpPrh002.Set := "FC_NoiseReal"(Base := 112.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh002.Act := "FC_NoiseReal"(Base := 112.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh002.Y := "FC_NoiseReal"(Base := 7.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpPrh003.Set := "FC_NoiseReal"(Base := 113.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh003.Act := "FC_NoiseReal"(Base := 113.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh003.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpPrh004.Set := "FC_NoiseReal"(Base := 114.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh004.Act := "FC_NoiseReal"(Base := 114.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh004.Y := "FC_NoiseReal"(Base := 33.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpPrh005.Set := "FC_NoiseReal"(Base := 114.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh005.Act := "FC_NoiseReal"(Base := 114.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpPrh005.Y := "FC_NoiseReal"(Base := 1.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Drawing 1..3
	    // =========================
	    "StrMdo".TmpDrw001.Set := "FC_NoiseReal"(Base := 73.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpDrw001.Act := "FC_NoiseReal"(Base := 73.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpDrw001.Y := "FC_NoiseReal"(Base := -13.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpDrw002.Set := "FC_NoiseReal"(Base := 75.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpDrw002.Act := "FC_NoiseReal"(Base := 75.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpDrw002.Y := "FC_NoiseReal"(Base := -22.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpDrw003.Set := "FC_NoiseReal"(Base := 80.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpDrw003.Act := "FC_NoiseReal"(Base := 80.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpDrw003.Y := "FC_NoiseReal"(Base := -13.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Annealing 1..2
	    // =========================
	    "StrMdo".TmpAnn001.Set := "FC_NoiseReal"(Base := 75.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpAnn001.Act := "FC_NoiseReal"(Base := 74.9, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpAnn001.Y := "FC_NoiseReal"(Base := -13.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "StrMdo".TmpAnn002.Set := "FC_NoiseReal"(Base := 75.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpAnn002.Act := "FC_NoiseReal"(Base := 75.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrMdo".TmpAnn002.Y := "FC_NoiseReal"(Base := -22.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
END_FUNCTION

FUNCTION "FC_Fluct_DB321_StrCas" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB321 (StrCas) - Chill Roll
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi
      Amp_SpdPct : Real;   // Â±%  (fan speed)
      Amp_PrsMbar : Real;   // Â±mbar
      Amp_TmpC : Real;   // Â±Â°C
      Amp_Y_Pct : Real;   // Â±% drive chill roll (m/min dan load %)
      Amp_SpdMpm : Real;   // Â± m/min
      Amp_LoaPct : Real;   // Â± %
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // =========================
	    // Drive Chill Roll (ambil dari DrvChr.*)
	    // =========================
	    "StrCas".DrvChr.SpdSet := "FC_NoiseReal"(Base := 28.3, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".DrvChr.SpdAct := "FC_NoiseReal"(Base := 28.3, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".DrvChr.LoaAct := "FC_NoiseReal"(Base := 0.6, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Air Knife Fan
	    // =========================
	    "StrCas".FanAkn.SpdAct := "FC_NoiseReal"(Base := 82.0, Amp := #Amp_SpdPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Pressure Air Knife (di layar hanya 0.0 mbar)
	    // =========================
	    "StrCas".PrsAkn.Set := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PrsMbar, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".PrsAkn.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PrsMbar, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".PrsAkn.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // All Zone (pakai setpoint utama Chill Roll)
	    // =========================
	    "StrCas".TmpAll.Set := "FC_NoiseReal"(Base := 35.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Chill Roll Temperature
	    // =========================
	    "StrCas".TmpChr.Set := "FC_NoiseReal"(Base := 35.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".TmpChr.Act := "FC_NoiseReal"(Base := 35.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".TmpChr.Y := "FC_NoiseReal"(Base := -33.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Water Bath Temperature
	    // =========================
	    "StrCas".TmpWba.Set := "FC_NoiseReal"(Base := 30.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".TmpWba.Act := "FC_NoiseReal"(Base := 31.4, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrCas".TmpWba.Y := "FC_NoiseReal"(Base := -99.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
END_FUNCTION

