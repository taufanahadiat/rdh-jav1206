      InpOvt : Bool;   // Input Over Temperatur
      InpSofSta : Bool;   // Input Soft Start
      InpSofStaRdy : Bool;   // Input Soft Start Ready
      Out001 : Bool;   // Output 1
      Out002 : Bool;   // Output 2
      Out003 : Bool;   // Output 3
      AlrMod : Word;   // Alarm Mode
      AlaSum : Bool;   // Alarm Summary
      AlaCbr : Bool;   // Alarm Circuit Breaker
      AlaSsw : Bool;   // Alarm Service Switch
      AlaOvt : Bool;   // Alarm Over Temperature
      AlaSofSta : Bool;   // Alarm Soft Start
      LivCou : Int;   // Live Counter
   END_STRUCT;

END_TYPE

