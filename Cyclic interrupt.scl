FUNCTION "FC_Fluct_DB300_SilDos" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB300 (SilDos)
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi per jenis nilai
      Amp_RatioPct : Real;   // Â±0.5 %
      Amp_FdgKgh : Real;   // Â±5.0 kg/h
      Amp_WeiKg : Real;   // Â±1.0 kg
      Amp_LvlKg : Real;   // Â±0.5 kg
      Amp_Y_Pct : Real;   // Â±1.0 %
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // =========================
	    // Dosing 1
	    // =========================
	    "SilDos".Dos001.RatAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_RatioPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos001.FdgAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos001.FdgSet := "FC_NoiseReal"(Base := 0.6, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos001.WeiAct := "FC_NoiseReal"(Base := 67.5, Amp := #Amp_WeiKg, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Dosing 2
	    // =========================
	    "SilDos".Dos002.RatAct := "FC_NoiseReal"(Base := 82.0, Amp := #Amp_RatioPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos002.FdgAct := "FC_NoiseReal"(Base := 982.0, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos002.FdgSet := "FC_NoiseReal"(Base := 1013.0, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos002.WeiAct := "FC_NoiseReal"(Base := 51.5, Amp := #Amp_WeiKg, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Dosing 3
	    // =========================
	    "SilDos".Dos003.RatAct := "FC_NoiseReal"(Base := 3.0, Amp := #Amp_RatioPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos003.FdgAct := "FC_NoiseReal"(Base := 35.9, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos003.FdgSet := "FC_NoiseReal"(Base := 37.6, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos003.WeiAct := "FC_NoiseReal"(Base := 8.7, Amp := #Amp_WeiKg, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Dosing 4
	    // =========================
	    "SilDos".Dos004.RatAct := "FC_NoiseReal"(Base := 15.0, Amp := #Amp_RatioPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos004.FdgAct := "FC_NoiseReal"(Base := 179.6, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos004.FdgSet := "FC_NoiseReal"(Base := 176.1, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".Dos004.WeiAct := "FC_NoiseReal"(Base := 20.5, Amp := #Amp_WeiKg, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Dosing Global
	    // =========================
	    "SilDos".DosGbl.FdgAct := "FC_NoiseReal"(Base := 1227.3, Amp := #Amp_FdgKgh, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".DosGbl.CmpAct := "FC_NoiseReal"(Base := 96505.7, Amp := (#Amp_WeiKg * 10.0), Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Level Control
	    // =========================
	    "SilDos".LvlCtl.Act := "FC_NoiseReal"(Base := 90.0, Amp := #Amp_LvlKg, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".LvlCtl.Set := "FC_NoiseReal"(Base := 90.0, Amp := #Amp_LvlKg, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "SilDos".LvlCtl.Y := "FC_NoiseReal"(Base := 60.2, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // PmtLvlCtl
	    "SilDos".PmtLvlCtl.Y := "FC_NoiseReal"(Base := 60.2, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
END_FUNCTION

DATA_BLOCK "DB_Sim"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
NON_RETAIN
