	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // ---- Drive ----
	    "ExtMel".Drv001.PowAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #Lo, Hi := #Hi, Seed := #Seed);
