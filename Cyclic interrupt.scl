FUNCTION "FC_NoiseReal" : Real
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// NOISE GENERATOR (REAL)
// ============================================================
   VAR_INPUT 
      Base : Real;   // nilai dasar
      Amp : Real;   // amplitudo (+/-)
      Lo : Real;   // clamp low
      Hi : Real;   // clamp high
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;   // seed harus disimpan di DB (retentive kalau perlu)
   END_VAR

   VAR_TEMP 
      rnd : Real;
      nrm : Real;
      v : Real;
      tmp : DInt;
   END_VAR


BEGIN
	    // LCG pseudo-random
	    #Seed := #Seed * 1103515245 + 12345;
	    
	    // jadikan 0..1 (hindari AND langsung ke REAL)
	    #tmp := #Seed AND 16#7FFFFFFF;
	    #rnd := DINT_TO_REAL(#tmp) / 2147483647.0;
	    
	    // -1 .. +1
	    #nrm := (#rnd - 0.5) * 2.0;
	    
	    // value
	    #v := #Base + (#nrm * #Amp);
	    
	    // clamp
	    IF #v < #Lo THEN
	        #v := #Lo;
	    END_IF;
	    IF #v > #Hi THEN
	        #v := #Hi;
	    END_IF;
	    
	    // return
	    #FC_NoiseReal := #v;
END_FUNCTION

