FUNCTION "FC_Fluct_Master" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.3
// ============================================================
// MASTER FC (panggil semua area/DB) - always enable semua DB
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // global enable saja
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    "FC_Fluct_DB300_SilDos"(
	                            Enable := TRUE,
	                            Amp_RatioPct := 0.5,
	                            Amp_FdgKgh := 5.0,
	                            Amp_WeiKg := 1.0,
	                            Amp_LvlKg := 0.5,
	                            Amp_Y_Pct := 1.0,
	                            Seed := #Seed
	    );
	    
	    "FC_Fluct_DB311_ExtMel"(
	                            Enable := TRUE,
	                            Amp_PowKw := 0.2,
	                            Amp_SpdRpm := 1.5,
	                            Amp_TmpC := 0.8,
	                            Amp_PrsBar := 0.3,
	                            Amp_Y_Pct := 1.0,
	                            Seed := #Seed
	    );
	    
	    "FC_Fluct_DB312_ExtMet"(
	                            Enable := TRUE,
	                            Amp_PowKw := 0.2,
	                            Amp_SpdRpm := 1.5,
	                            Amp_TmpC := 0.8,
	                            Amp_Y_Pct := 1.0,
	                            Amp_PrsBar := 0.3,
	                            Seed := #Seed
	    );
	    
	    "FC_Fluct_DB313_ExtFil"(
	                            Enable := TRUE,
	                            Amp_TmpC := 0.8,
	                            Amp_PrsBar := 0.3,
	                            Amp_Y_Pct := 1.0,
	                            Seed := #Seed
	    );
	    
	    "FC_Fluct_DB314_ExtDie"(
	                            Enable := TRUE,
	                            Amp_TmpC := 0.8,
	                            Amp_Y_Pct := 1.0,
	                            Seed := #Seed
	    );
	    
	    "FC_Fluct_DB315_ExtDieBlt"(
	                               Enable := TRUE,
	                               Amp_TmpC := 0.8,
	                               Seed := #Seed
	    );
	    
	    "FC_Fluct_DB316_ExtCox001"(
	                               Enable := TRUE,
	                               Amp_PowKw := 0.2,
	                               Amp_SpdRpm := 1.5,
	                               Amp_LoaPct := 1.0,
	                               Amp_TmpC := 0.8,
	                               Amp_PrsBar := 0.3,
	                               Amp_Y_Pct := 1.0,
	                               Seed := #Seed
	    );
	    
	    "FC_Fluct_DB317_ExtCox002"(
	                               Enable := TRUE,
	                               Amp_PowKw := 0.2,
	                               Amp_SpdRpm := 1.5,
	                               Amp_TmpC := 0.8,
	                               Amp_PrsBar := 0.3,
	                               Amp_Y_Pct := 1.0,
	                               Amp_LoaPct := 1.0,
	                               Seed := #Seed
	    );
	    
	    "FC_Fluct_DB321_StrCas"(
	                            Enable := TRUE,
	                            Amp_SpdPct := 1.0,
	                            Amp_PrsMbar := 5.0,
	                            Amp_TmpC := 0.8,
	                            Amp_Y_Pct := 1.0,
	                            Amp_SpdMpm := 0.3,
	                            Amp_LoaPct := 0.5,
	                            Seed := #Seed
	    );
	    
	    "FC_Fluct_DB322_StrMdo"(
	                            Enable := TRUE,
	                            Amp_TmpC := 0.8,
	                            Amp_Y_Pct := 1.0,
	                            Amp_SpdMpm := 0.5,
	                            Amp_LoaPct := 1.0,
	                            Seed := #Seed
	    );
	    
