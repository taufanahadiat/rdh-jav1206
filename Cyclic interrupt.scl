	                               Amp_Loa_Pct := 1.0,
	                               Seed := #Seed
	    );
	    
	    "FC_Fluct_DB326_StrPur"(
	                            Enable := TRUE,
	                            Amp_TmpC := 0.8,
	                            Amp_Y_Pct := 1.0,
	                            Amp_SpdMpm := 0.8,
