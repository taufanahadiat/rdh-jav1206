FUNCTION "FC_Fluct_DB326_StrPur" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      Enable : Bool;   // amplitudo (silakan kamu adjust)
      Amp_TmpC : Real;   // Â±Â°C
      Amp_Y_Pct : Real;   // Â±%
      Amp_SpdMpm : Real;   // Â± m/min (Pull Roll)
      Amp_LoaPct : Real;   // Â± % (Friction/Load)
      Amp_PowKw : Real;   // Â± kW (kalau PowAct real) Corona generator speed (WORD/UINT)
      Amp_CorSpd : UInt;   // Â±5 (unit speed corona)
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      LoR : Real;
      HiR : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #LoR := -3.4E38;
	    #HiR := 3.4E38;
	    
	    // =========================================================
	    // HCU INLET + HCU1..HCU5 (base dari screenshot)
	    // =========================================================
	    "StrPur".TmpHcuInl.Set := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcuInl.Act := "FC_NoiseReal"(Base := 1999.9, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcuInl.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    "StrPur".TmpHcu001.Set := "FC_NoiseReal"(Base := 30.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu001.Act := "FC_NoiseReal"(Base := 29.6, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu001.Y := "FC_NoiseReal"(Base := 28.0, Amp := #Amp_Y_Pct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    "StrPur".TmpHcu002.Set := "FC_NoiseReal"(Base := 30.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu002.Act := "FC_NoiseReal"(Base := 29.8, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu002.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    "StrPur".TmpHcu003.Set := "FC_NoiseReal"(Base := 25.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu003.Act := "FC_NoiseReal"(Base := 25.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu003.Y := "FC_NoiseReal"(Base := -1.0, Amp := #Amp_Y_Pct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    "StrPur".TmpHcu004.Set := "FC_NoiseReal"(Base := 50.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu004.Act := "FC_NoiseReal"(Base := 50.2, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu004.Y := "FC_NoiseReal"(Base := 27.0, Amp := #Amp_Y_Pct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    "StrPur".TmpHcu005.Set := "FC_NoiseReal"(Base := 55.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu005.Act := "FC_NoiseReal"(Base := 55.2, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpHcu005.Y := "FC_NoiseReal"(Base := 15.0, Amp := #Amp_Y_Pct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    // =========================================================
	    // Pull Roll Drives 1..5 (base dari screenshot)
	    // NOTE: aku anggap LoaAct = Friction (%)
	    // PowAct/TmpAct belum terlihat -> base default
	    // =========================================================
	    // Drv001 (Pull Roll 1)
	    "StrPur".Drv001.SpdSet := "FC_NoiseReal"(Base := 175.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv001.SpdAct := "FC_NoiseReal"(Base := 172.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv001.LoaAct := "FC_NoiseReal"(Base := -1.95, Amp := #Amp_LoaPct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv001.PowAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv001.TmpAct := "FC_NoiseReal"(Base := 45.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    // Drv002 (Pull Roll 2)
	    "StrPur".Drv002.SpdSet := "FC_NoiseReal"(Base := 166.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv002.SpdAct := "FC_NoiseReal"(Base := 166.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv002.LoaAct := "FC_NoiseReal"(Base := -3.10, Amp := #Amp_LoaPct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv002.PowAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv002.TmpAct := "FC_NoiseReal"(Base := 45.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    // Drv003 (Pull Roll 3)
	    "StrPur".Drv003.SpdSet := "FC_NoiseReal"(Base := 172.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv003.SpdAct := "FC_NoiseReal"(Base := 172.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv003.LoaAct := "FC_NoiseReal"(Base := 3.80, Amp := #Amp_LoaPct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv003.PowAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv003.TmpAct := "FC_NoiseReal"(Base := 45.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    // Drv004 (Pull Roll 4)
	    "StrPur".Drv004.SpdSet := "FC_NoiseReal"(Base := 173.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv004.SpdAct := "FC_NoiseReal"(Base := 173.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv004.LoaAct := "FC_NoiseReal"(Base := 0.15, Amp := #Amp_LoaPct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv004.PowAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv004.TmpAct := "FC_NoiseReal"(Base := 45.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    // Drv005 (Pull Roll 5)
	    "StrPur".Drv005.SpdSet := "FC_NoiseReal"(Base := 173.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv005.SpdAct := "FC_NoiseReal"(Base := 173.0, Amp := #Amp_SpdMpm, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv005.LoaAct := "FC_NoiseReal"(Base := -0.15, Amp := #Amp_LoaPct, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv005.PowAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".Drv005.TmpAct := "FC_NoiseReal"(Base := 45.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    // =========================================================
	    // Lain-lain dari list kamu (base default dulu)
	    // =========================================================
	    "StrPur"."0".Set := "FC_NoiseReal"(Base := 35.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);  // All Zone di layar
	    "StrPur".TmpCor001.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpCor002.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TmpFla.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_TmpC, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".EdtAmp.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PowKw, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    
	    //TCE
	    "StrPur".TCE.rAvgThick := "FC_NoiseReal"(Base := 24.76, Amp := 0.001, Lo := #LoR, Hi := #HiR, Seed := #Seed);
	    "StrPur".TCE.rWebWidth := 5802;
END_FUNCTION

FUNCTION_BLOCK "FC_Fluct_DB330_Win"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.2
// ============================================================
// FLUCTUATION DB330 (Win / Winder)
// ============================================================
   VAR_INPUT 
      Enable : Bool;
      Amp_SpdMpm : Real;   // Â± m/min
      Amp_LoaPct : Real;   // Â± %
      Amp_PowKw : Real;   // Â± kW
      Amp_TmpC : Real;   // Â± Â°C
      Amp_TenNm : Real;   // Â± Nm (tension)
      Amp_PrsN : Real;   // Â± N (pressure force)
      Amp_PosMm : Real;   // Â± mm / deg / position
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR 
      FirstScanDone : Bool;   // penanda startup CPU / first call
      SeqMco : Int;   // 0=idle, 1=Rst ON, 2=Rel ON
      McoReachedLatch : Bool;   // latch trigger saat setpoint tercapai
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
      LineSpd : Real;
      McoStep : Real;
      McoRemain : Real;
      CycleMin : Real;
      Cycle_ms : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // default pulse output OFF setiap scan
	    "Win".Msc.Mco.Rst := FALSE;
	    "Win".Msc.Mco.Rel := FALSE;
	    
	    // =====================================================
	    // STARTUP CPU / FIRST SCAN
	    // Pulse: Rel TRUE lalu scan berikutnya FALSE
	    // =====================================================
	    IF NOT #FirstScanDone THEN
	        #FirstScanDone := TRUE;
	        #SeqMco := 2;   // langsung jalankan step REL pulse
	    END_IF;
	    
	    // =========================
	    // CON (Contact Roll / Conveyor)
	    // =========================
	    "Win".Con.Drv.LoaAct := "FC_NoiseReal"(Base := 1.60, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.Drv.SpdSet := "FC_NoiseReal"(Base := 177.7, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.Drv.SpdAct := "FC_NoiseReal"(Base := 171.2, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "Win".Con.PrsAct.Act := "FC_NoiseReal"(Base := 1048.0, Amp := #Amp_PrsN, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.PosDif.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "Win".Con.DrvPosDrs.PosAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.DrvPosDrs.SpdAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.DrvPosDrs.LoaAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "Win".Con.DrvPosOps.PosAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.DrvPosOps.SpdAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Con.DrvPosOps.LoaAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // TURNING
	    // =========================
	    "Win".Trn.Drv.SpdSet := "FC_NoiseReal"(Base := 80.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Trn.Drv.SpdAct := "FC_NoiseReal"(Base := 80.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Trn.Drv.LoaAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "Win".Trn.Pos.Act := "FC_NoiseReal"(Base := 359.78, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Trn.PosCal.Set := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // CUTTING ARM / MISC
	    // =========================
	    "Win".Cua.VlvPos.PosAct := "FC_NoiseReal"(Base := 0.05, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Cua.VlvPos.SpdSet := "FC_NoiseReal"(Base := -60.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Cua.NotPrk.Set := "FC_NoiseReal"(Base := 120.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Cua.CroCut.SpdSetCmd := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".Cua.CroCut.SpdAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // MCO
	    // =========================
	    // Satuan:
	    // - SpdAct  : m/min
	    // - Mco.Set : m
	    // - Mco.Act : m
	    // - Mco.Tim : min
	   
	    
	    #LineSpd := "StrTdoOut".Drv001.SpdAct;   // m/min
	    #Cycle_ms := 100.0;
	    #CycleMin := #Cycle_ms / 60000.0;        // ms -> min
	    #McoStep := #LineSpd * #CycleMin;        // m per cycle
	    
	    // Counter hanya jalan saat tidak sedang sequence reset/release
	    IF #SeqMco = 0 THEN
	        IF "Win".Msc.Mco.Act < "Win".Msc.Mco.Set THEN
	            "Win".Msc.Mco.Act := "Win".Msc.Mco.Act + #McoStep;
	            
	            IF "Win".Msc.Mco.Act >= "Win".Msc.Mco.Set THEN
	                "Win".Msc.Mco.Act := "Win".Msc.Mco.Set;
	                #McoReachedLatch := TRUE;
	            END_IF;
	        END_IF;
	    END_IF;
	    
	    // Remaining meter
	    #McoRemain := "Win".Msc.Mco.Set - "Win".Msc.Mco.Act;
	    IF #McoRemain < 0.0 THEN
	        #McoRemain := 0.0;
	    END_IF;
	    
	    // Time remaining dalam menit
	    IF #LineSpd > 0.0 THEN
	        "Win".Msc.Mco.Tim := #McoRemain / #LineSpd;
	    ELSE
	        "Win".Msc.Mco.Tim := 0.0;
	    END_IF;
	    
	    // Trigger sequence jika setpoint tercapai
	    IF (#McoReachedLatch) AND (#SeqMco = 0) THEN
	        #McoReachedLatch := FALSE;
	        #SeqMco := 1;
	    END_IF;
	    
	    // Sequential pulse:
	    // step 1 : Rst TRUE
	    // step 2 : Rst FALSE, Rel TRUE, reset Act ke 0
	    // step 0 : semua FALSE
	    CASE #SeqMco OF
	        0:
	            ;
	        1:
	            "Win".Msc.Mco.Rst := TRUE;
	            #SeqMco := 2;
	            
	        2:
	            "Win".Msc.Mco.Rel := TRUE;
	            "Win".Msc.Mco.Act := 0.0;
	            #SeqMco := 0;
	        ELSE
	            #SeqMco := 0;
	    END_CASE;
	    
	    "Win".Msc.AutCycTim.Act := "FC_NoiseReal"(Base := 300.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // WINDER 1 & 2
	    // =========================
	    "Win".W01.Drv.SpdSet := "FC_NoiseReal"(Base := 177.7, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W01.Drv.SpdAct := "FC_NoiseReal"(Base := 171.2, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W01.Drv.LoaAct := "FC_NoiseReal"(Base := 10.3, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W01.Gbl.TenSet := "FC_NoiseReal"(Base := 232.4, Amp := #Amp_TenNm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W01.Gbl.ScwTenSet := "FC_NoiseReal"(Base := 15.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W01.Prs.SetAct := "FC_NoiseReal"(Base := 1059.0, Amp := #Amp_PrsN, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W01.Dia.Act := "FC_NoiseReal"(Base := 576.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "Win".W02.Drv.SpdSet := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W02.Drv.SpdAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W02.Drv.LoaAct := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W02.Gbl.TenSet := "FC_NoiseReal"(Base := 234.4, Amp := #Amp_TenNm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W02.Gbl.ScwTenSet := "FC_NoiseReal"(Base := 15.0, Amp := #Amp_LoaPct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W02.Prs.SetAct := "FC_NoiseReal"(Base := 1056.0, Amp := #Amp_PrsN, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "Win".W02.Dia.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PosMm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
END_FUNCTION_BLOCK

FUNCTION "FC_Fluct_DB325_StrTdoOut" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB325 (StrTdoOut) - TDO Outlet
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi
      Amp_TmpC : Real;   // Â±Â°C
      Amp_Y_Pct : Real;   // Â±%
      Amp_SpdMpm : Real;   // Â± m/min
      Amp_Loa_Pct : Real;   // Â± %
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // -------------------------
	    // Drive TDO Outlet (Drv001)
	    // -------------------------
	    "StrTdoOut".Drv001.SpdSet := "FC_NoiseReal"(Base := 175.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".Drv001.SpdAct := "FC_NoiseReal"(Base := 175.0, Amp := #Amp_SpdMpm, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".Drv001.LoaAct := "FC_NoiseReal"(Base := 20.8, Amp := #Amp_Loa_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // -------------------------
	    // All Zone
	    // -------------------------
	    "StrTdoOut".TmpAll.Set := "FC_NoiseReal"(Base := 145.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // -------------------------
	    // Annealing 1.1 (Ann011)
	    // -------------------------
	    "StrTdoOut".TmpAnn011.Set := "FC_NoiseReal"(Base := 145.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn011.Act := "FC_NoiseReal"(Base := 145.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn011.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Annealing 1.2 (Ann012)
	    "StrTdoOut".TmpAnn012.Set := "FC_NoiseReal"(Base := 145.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn012.Act := "FC_NoiseReal"(Base := 148.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn012.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // -------------------------
	    // Annealing 2.1 (Ann021)
	    // -------------------------
	    "StrTdoOut".TmpAnn021.Set := "FC_NoiseReal"(Base := 135.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn021.Act := "FC_NoiseReal"(Base := 134.7, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn021.Y := "FC_NoiseReal"(Base := 3.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Annealing 2.2 (Ann022)
	    "StrTdoOut".TmpAnn022.Set := "FC_NoiseReal"(Base := 135.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn022.Act := "FC_NoiseReal"(Base := 136.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn022.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // -------------------------
	    // Annealing 3.1 (Ann031)
	    // -------------------------
	    "StrTdoOut".TmpAnn031.Set := "FC_NoiseReal"(Base := 135.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn031.Act := "FC_NoiseReal"(Base := 135.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn031.Y := "FC_NoiseReal"(Base := 8.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Annealing 3.2 (Ann032)
	    "StrTdoOut".TmpAnn032.Set := "FC_NoiseReal"(Base := 135.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn032.Act := "FC_NoiseReal"(Base := 133.5, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoOut".TmpAnn032.Y := "FC_NoiseReal"(Base := 11.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
END_FUNCTION

FUNCTION "FC_Fluct_DB323_324_TdoInlMid" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB323 + DB324
// AREA: StrTdoInl + StrTdoMid
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi
      Amp_TmpC : Real;   // Â±Â°C
      Amp_Y_Pct : Real;   // Â±%
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // =====================================================
	    // DB323 - StrTdoInl
	    // =====================================================
	    
	    // All Zone
	    "StrTdoInl".TmpAll.Set := "FC_NoiseReal"(Base := 179.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Preheating 1
	    "StrTdoInl".TmpPrh001.Set := "FC_NoiseReal"(Base := 164.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoInl".TmpPrh001.Act := "FC_NoiseReal"(Base := 164.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoInl".TmpPrh001.Y := "FC_NoiseReal"(Base := 35.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Preheating 2
	    "StrTdoInl".TmpPrh002.Set := "FC_NoiseReal"(Base := 174.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoInl".TmpPrh002.Act := "FC_NoiseReal"(Base := 173.3, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoInl".TmpPrh002.Y := "FC_NoiseReal"(Base := 100.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Preheating 3
	    "StrTdoInl".TmpPrh003.Set := "FC_NoiseReal"(Base := 179.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoInl".TmpPrh003.Act := "FC_NoiseReal"(Base := 179.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoInl".TmpPrh003.Y := "FC_NoiseReal"(Base := 20.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =====================================================
	    // DB324 - StrTdoMid
	    // =====================================================
	    
	    // All Zone
	    "StrTdoMid".TmpAll.Set := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 1.1
	    "StrTdoMid".TmpDrw011.Set := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw011.Act := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw011.Y := "FC_NoiseReal"(Base := 54.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 1.2
	    "StrTdoMid".TmpDrw012.Set := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw012.Act := "FC_NoiseReal"(Base := 156.8, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw012.Y := "FC_NoiseReal"(Base := 14.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 2.1
	    "StrTdoMid".TmpDrw021.Set := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw021.Act := "FC_NoiseReal"(Base := 156.9, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw021.Y := "FC_NoiseReal"(Base := 4.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 2.2
	    "StrTdoMid".TmpDrw022.Set := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw022.Act := "FC_NoiseReal"(Base := 157.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw022.Y := "FC_NoiseReal"(Base := 2.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 3.1
	    "StrTdoMid".TmpDrw031.Set := "FC_NoiseReal"(Base := 156.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw031.Act := "FC_NoiseReal"(Base := 156.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw031.Y := "FC_NoiseReal"(Base := 63.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 3.2
	    "StrTdoMid".TmpDrw032.Set := "FC_NoiseReal"(Base := 156.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw032.Act := "FC_NoiseReal"(Base := 155.8, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw032.Y := "FC_NoiseReal"(Base := 10.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 4.1
	    "StrTdoMid".TmpDrw041.Set := "FC_NoiseReal"(Base := 155.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw041.Act := "FC_NoiseReal"(Base := 154.3, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw041.Y := "FC_NoiseReal"(Base := 3.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Drawing 4.2
	    "StrTdoMid".TmpDrw042.Set := "FC_NoiseReal"(Base := 155.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw042.Act := "FC_NoiseReal"(Base := 156.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "StrTdoMid".TmpDrw042.Y := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
END_FUNCTION

FUNCTION "FC_Fluct_DB313_ExtFil" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
// ============================================================
// FLUCTUATION DB313 (ExtFil)
// ============================================================
   VAR_INPUT 
      Enable : Bool;   // amplitudo fluktuasi
      Amp_TmpC : Real;   // Â±Â°C
      Amp_PrsBar : Real;   // Â±bar
      Amp_Y_Pct : Real;   // Â±%
   END_VAR

   VAR_IN_OUT 
      Seed : DInt;
   END_VAR

   VAR_TEMP 
      Lo : Real;
      Hi : Real;
   END_VAR


BEGIN
	    IF NOT #Enable THEN
	        RETURN;
	    END_IF;
	    
	    #Lo := -3.4E38;
	    #Hi := 3.4E38;
	    
	    // =========================
	    // Pressure (S7_PRS) - base dari gambar + comment ExtFil.db
	    // Prs001: before filter  (Press P3 = 97.9 bar)
	    // Prs002: after filter   (Press P2 = 135.6 bar)
	    // Prs012: diff pressure  (Diff Press = 37.7 bar)
	    // Prs003: before die     (Press P4 = 0.0 bar)
	    // =========================
	    "ExtFil".Prs001.Act := "FC_NoiseReal"(Base := 97.9, Amp := #Amp_PrsBar, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".Prs002.Act := "FC_NoiseReal"(Base := 135.6, Amp := #Amp_PrsBar, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".Prs012.Act := "FC_NoiseReal"(Base := 37.7, Amp := #Amp_PrsBar, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".Prs003.Act := "FC_NoiseReal"(Base := 0.0, Amp := #Amp_PrsBar, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Melt Temp (S7_ACT) - base dari gambar
	    // TmpMel001: before filter (Melt Temp T3 = 241.1 Â°C)
	    // TmpMel002: after filter  (Melt Temp T2 = 244.6 Â°C)
	    // TmpMel003: before die    (Melt Temp T4 = 1999.9 Â°C)  // sesuai tampilan
	    // TmpMel004: preheating filter (Pre.Filter = 32.4 Â°C)
	    // =========================
	    "ExtFil".TmpMel001.Act := "FC_NoiseReal"(Base := 241.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpMel002.Act := "FC_NoiseReal"(Base := 244.6, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpMel003.Act := "FC_NoiseReal"(Base := 1999.9, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpMel004.Act := "FC_NoiseReal"(Base := 32.4, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // All Zone
	    // =========================
	    "ExtFil".TmpAll.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // =========================
	    // Adapter / Pipe / Filter (CTL_GEN): .Act / .Set / .Y
	    // =========================
	    
	    // Adapter (kanan)
	    "ExtFil".TmpAdp.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpAdp.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpAdp.Y := "FC_NoiseReal"(Base := 39.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Adapter 1 (bawah kanan)
	    "ExtFil".TmpAdp001.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpAdp001.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpAdp001.Y := "FC_NoiseReal"(Base := 31.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Adapter 2 (bawah kiri)
	    "ExtFil".TmpAdp002.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpAdp002.Act := "FC_NoiseReal"(Base := 235.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpAdp002.Y := "FC_NoiseReal"(Base := 45.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Pipe 2.1 .. 2.4
	    "ExtFil".TmpPip021.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip021.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip021.Y := "FC_NoiseReal"(Base := 62.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpPip022.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip022.Act := "FC_NoiseReal"(Base := 234.9, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip022.Y := "FC_NoiseReal"(Base := 16.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpPip023.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip023.Act := "FC_NoiseReal"(Base := 235.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip023.Y := "FC_NoiseReal"(Base := 90.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpPip024.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip024.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip024.Y := "FC_NoiseReal"(Base := 36.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Filter 1..3
	    "ExtFil".TmpFil001.Set := "FC_NoiseReal"(Base := 255.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpFil001.Act := "FC_NoiseReal"(Base := 255.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpFil001.Y := "FC_NoiseReal"(Base := 16.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpFil002.Set := "FC_NoiseReal"(Base := 255.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpFil002.Act := "FC_NoiseReal"(Base := 255.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpFil002.Y := "FC_NoiseReal"(Base := 20.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpFil003.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpFil003.Act := "FC_NoiseReal"(Base := 235.2, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpFil003.Y := "FC_NoiseReal"(Base := 14.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    // Pipe 3.1 .. 3.5
	    "ExtFil".TmpPip031.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip031.Act := "FC_NoiseReal"(Base := 235.1, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip031.Y := "FC_NoiseReal"(Base := 53.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpPip032.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip032.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip032.Y := "FC_NoiseReal"(Base := 9.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpPip033.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip033.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip033.Y := "FC_NoiseReal"(Base := 7.0, Amp := #Amp_Y_Pct, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    
	    "ExtFil".TmpPip034.Set := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
	    "ExtFil".TmpPip034.Act := "FC_NoiseReal"(Base := 235.0, Amp := #Amp_TmpC, Lo := #Lo, Hi := #Hi, Seed := #Seed);
